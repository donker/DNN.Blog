            "supportsPartialRendering": "False",
            "controlTitle": "Blog Settings",
            "controlType": "Edit",
            "viewOrder": 0
          }
        ]
      }
    ]
  },
  "pathsAndFiles": {
    "pathToAssemblies": "./bin",
    "assemblies": ["Dnn.Modules.Blog.dll"],
    "excludeFilter": ["Blog/bin/", "Blog/obj/"]
  }
}
