{
  "name": "DNN Community.Blog",
  "projectType": "module",
  "friendlyName": "Blog Module",
  "description": "DNN Community Blog Module",
  "packageName": "DNN Community_Blog",
  "folder": "MVC/DNN Community/Blog",
  "iconFile": "DesktopModules\\MVC\\DNN Community\\Blog\\icon.png",
  "module": {
    "azureCompatible": "true",
    "moduleName": "DNN Community_Blog",
    "foldername": "DNN Community/Blog",
    "businessControllerClass": "Dnn.Modules.Blog.Common.ModuleController, DNN.MODULES.BLOG",
