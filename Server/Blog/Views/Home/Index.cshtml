@inherits BlogWebPage
@using Dnn.Modules.Blog.Common
@{
  BlogModuleContext.AddModuleScript();
}

<h1>Hello Blog Module</h1>

<div class="DNN CommunityBlog Blog"
     data-locale="@System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName"
