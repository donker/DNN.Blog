{
  "name": "dnn-blog",
  "version": "6.4.2",
  "description": "The DotNetNuke Blog module is an easy to use content publishing module that is tightly integrated with the core DotNetNuke framework. It can be used in single or multi-author environments and also permits content authoring using off-site tools such as Windows Live Writer.",
  "dnn": {
    "projectFolders": [
      "Server/Blog"
    ],
    "owner": {
      "name": "Peter Donker",
      "organization": "DNN Community",
      "url": "https://dnncommunity.org",
      "email": "info@dnncommunity.org"
    },
    "pathsAndFiles": {
      "solutionFile": "./DotNetNuke.Modules.Blog.sln",
      "pathToAssemblies": "./bin",
      "excludeFilter": [
        "**/bin/**/*",
        "**/obj/**/*",
        "**/node_modules/**/*",
        "**/*.??-??.resx"
      ],
      "licenseFile": "./License.txt",
      "releaseNotesFile": "./ReleaseNotes.md",
      "releaseFiles": [
        "**/*.resx",
        "**/*.as?x",
        "**/*.js",
        "**/*.css",
        "**/*.html",
        "**/*.png",
        "**/*.gif",
        "**/*.txt",
        "fonts/*.*",
        "images/*.*",
        "Templates/*.xsd",
        "Templates/**/*.xml"
      ],
      "zipName": "Blog"
    }
  },
  "scripts": {
    "watch-server": "node watch.js"
  },
  "devDependencies": {
    "@types/jquery": "^3.3.34",
    "@types/react": "^16.9.34",
    "@types/react-dom": "^16.9.6",
    "chokidar": "^3.2.1",
    "deepmerge": "^4.0.0",
    "fs-extra": "^8.1.0",
    "jquery": "^3.5.0"
  },
  "dependencies": {
    "react": "^16.13.1",
    "react-dom": "^16.13.1"
  }
}
